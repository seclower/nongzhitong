/* 订单详情页面样式 - 绿色科技感金属风格 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  padding-bottom: 120rpx;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 订单状态 */
.order-status-section {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  padding: 40rpx 20rpx;
  margin: 30rpx 30rpx 20rpx;
  text-align: center;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  position: relative;
  z-index: 1;
}

.order-status {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

.order-status-desc {
  font-size: 24rpx;
  opacity: 0.9;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

/* 订单信息 */
.order-info {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.order-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.2);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.info-value {
  font-size: 26rpx;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

/* 收货地址 */
.address-section {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.address-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.address-info {
  padding-left: 20rpx;
  border-left: 4rpx solid #00ff88;
}

.address-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 10rpx;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.address-detail {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

/* 商品信息 */
.products-section {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.products-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.product-item {
  display: flex;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.2);
}

.product-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  background: rgba(0, 255, 136, 0.1);
  border-radius: 16rpx;
  margin-right: 20rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 26rpx;
  color: #ffffff;
  margin-bottom: 10rpx;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.product-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 价格信息 */
.price-section {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin: 0 30rpx 120rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.price-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.2);
}

.price-item:last-child {
  border-bottom: none;
}

.price-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.price-value {
  font-size: 26rpx;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.price-item.total {
  margin-top: 10rpx;
}

.price-item.total .price-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.price-item.total .price-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  border-top: 2rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 -2rpx 20rpx rgba(0, 255, 136, 0.3);
  z-index: 1000;
}

.cancel-btn {
  flex: 1;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(244, 67, 54, 0.9) 0%, rgba(211, 47, 47, 0.8) 100%);
  color: white;
  border: 2rpx solid rgba(244, 67, 54, 0.4);
  border-radius: 16rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(244, 67, 54, 0.3);
  transition: all 0.3s ease;
  text-shadow: 0 0 10rpx rgba(244, 67, 54, 0.5);
}

.cancel-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(244, 67, 54, 0.4);
}

.pay-btn {
  flex: 1;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.pay-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
}