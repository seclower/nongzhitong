<!-- 我的收藏页面 -->
<view class="container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-title">我的收藏</view>
    <view class="header-right"></view>
  </view>
  
  <view class="favorites-list">
    <view class="product-item" wx:for="{{favorites}}" wx:key="{{item.id}}" bindtap="goToProductDetail" data-id="{{item.id}}">
      <view class="product-image">
        <image src="{{item.image}}" mode="aspectFill"></image>
      </view>
      <view class="product-info">
        <view class="product-name">{{item.name}}</view>
        <view class="product-price">
          <text class="price-current">¥{{item.price}}</text>
          <text class="price-original" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
        </view>
        <view class="product-sales">已售{{item.sales}}件</view>
      </view>
    </view>
  </view>
  
  <view class="empty" wx:if="{{favorites.length === 0}}">
    <text class="empty-icon">☆</text>
    <text class="empty-text">暂无收藏</text>
  </view>
</view>