/* 活动页面样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: white;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.back {
  font-size: 36rpx;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  cursor: pointer;
  transition: all 0.3s ease;
}

.back:hover {
  transform: translateX(-10rpx);
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.8);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.placeholder {
  width: 100rpx;
}

/* 活动内容 */
.activity-content {
  margin-top: 120rpx;
  position: relative;
  z-index: 1;
}

.activity-image {
  width: 100%;
  height: 500rpx;
  overflow: hidden;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  position: relative;
}

.activity-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.activity-image::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.2) 0%, rgba(10, 46, 26, 0.1) 100%);
  pointer-events: none;
}

.activity-info {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 40rpx 30rpx;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.activity-info:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.activity-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.activity-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 6rpx solid #00ff88;
  padding-left: 20rpx;
}

.activity-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 30rpx;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.activity-description {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
  padding-left: 20rpx;
  border-left: 4rpx solid rgba(0, 255, 136, 0.3);
}

.activity-rules {
  margin-top: 30rpx;
}

.rule-item {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
  color: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: flex-start;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
  padding-left: 20rpx;
  border-left: 4rpx solid rgba(0, 255, 136, 0.2);
}

/* 活动产品 */
.activity-products {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  margin: 30rpx;
  border-radius: 20rpx;
}

.activity-products:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.activity-products::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 6rpx solid #00ff88;
  padding-left: 20rpx;
}

.product-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.product-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  transition: all 0.3s ease;
  text-align: center;
  cursor: pointer;
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.product-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.product-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.product-image {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.1) 0%, rgba(0, 204, 106, 0.05) 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16rpx;
}

.product-name {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  line-height: 1.4;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.product-price {
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 36rpx;
  font-weight: 600;
  color: #00ff88;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

.price-original {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
  margin-left: 16rpx;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
}

/* 金属感效果增强 */
.activity-info,
.activity-products,
.product-item {
  background: linear-gradient(
    135deg,
    rgba(15, 60, 35, 0.95) 0%,
    rgba(10, 46, 26, 0.9) 50%,
    rgba(15, 60, 35, 0.95) 100%
  );
  box-shadow: 
    0 4rpx 20rpx rgba(0, 255, 136, 0.2),
    inset 0 0 30rpx rgba(0, 255, 136, 0.05);
}

/* 发光效果 */
.activity-info,
.activity-products,
.product-item {
  position: relative;
  overflow: hidden;
}

.activity-info::after,
.activity-products::after,
.product-item::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(0, 255, 136, 0.1) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
  pointer-events: none;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}