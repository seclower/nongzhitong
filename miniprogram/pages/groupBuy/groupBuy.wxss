/* 超值拼团页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background-color: #6B8E6E;
  color: white;
  padding: 0 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
}

.header-left, .header-right {
  width: 88rpx;
  text-align: center;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
}

/* 拼团商品列表 */
.group-buy-list {
  margin-top: 88rpx;
  padding: 20rpx;
}

.group-buy-item {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.group-buy-image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.group-buy-info {
  flex: 1;
}

.group-buy-title {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  line-height: 40rpx;
}

.group-buy-price {
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-right: 16rpx;
}

.price-original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.group-buy-progress {
  margin-bottom: 20rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background-color: #6B8E6E;
  border-radius: 4rpx;
}

.progress-text {
  font-size: 20rpx;
  color: #666;
  text-align: right;
}

.group-buy-actions {
  display: flex;
  justify-content: flex-end;
}

.join-btn {
  background-color: #6B8E6E;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
}
