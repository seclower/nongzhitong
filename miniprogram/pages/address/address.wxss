/* 收货地址页面样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
  padding-bottom: 140rpx;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: white;
  position: sticky;
  top: 0;
  z-index: 1000;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-left, .header-right {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  transition: all 0.3s ease;
}

.back-icon:hover {
  transform: translateX(-10rpx);
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.8);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  flex: 1;
  text-align: center;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 地址列表 */
.address-list {
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.address-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.address-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.address-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-right: 20rpx;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.address-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
}

.address-default {
  margin-left: auto;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.address-detail {
  font-size: 28rpx;
  line-height: 1.4;
  margin-bottom: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
  padding-left: 20rpx;
  border-left: 4rpx solid rgba(0, 255, 136, 0.5);
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 255, 136, 0.1);
}

.action-btn {
  font-size: 26rpx;
  padding: 10rpx 24rpx;
  border-radius: 15rpx;
  transition: all 0.3s ease;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid transparent;
}

.action-btn.edit {
  background: rgba(0, 255, 136, 0.1);
  color: #00ff88;
  border-color: rgba(0, 255, 136, 0.4);
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.2);
}

.action-btn.edit:hover {
  background: rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.4);
  border-color: rgba(0, 255, 136, 0.6);
  transform: translateY(-2rpx);
}

.action-btn.delete {
  background: rgba(244, 67, 54, 0.1);
  color: #ff6b6b;
  border-color: rgba(244, 67, 54, 0.4);
  box-shadow: 0 0 10rpx rgba(244, 67, 54, 0.2);
}

.action-btn.delete:hover {
  background: rgba(244, 67, 54, 0.2);
  box-shadow: 0 0 20rpx rgba(244, 67, 54, 0.4);
  border-color: rgba(244, 67, 54, 0.6);
  transform: translateY(-2rpx);
}

.action-btn.default {
  background: rgba(0, 255, 136, 0.1);
  color: #00ff88;
  border-color: rgba(0, 255, 136, 0.4);
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.2);
}

.action-btn.default:hover {
  background: rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.4);
  border-color: rgba(0, 255, 136, 0.6);
  transform: translateY(-2rpx);
}

/* 添加按钮 */
.add-button {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  border-radius: 25rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  box-shadow: 0 4rpx 25rpx rgba(0, 255, 136, 0.4);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  transition: all 0.3s ease;
  z-index: 1000;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  backdrop-filter: blur(10px);
}

.add-button:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 35rpx rgba(0, 255, 136, 0.5);
  border-color: rgba(0, 255, 136, 0.6);
}

.add-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.8);
}

/* 金属感效果增强 */
.address-item {
  background: linear-gradient(
    135deg,
    rgba(15, 60, 35, 0.95) 0%,
    rgba(10, 46, 26, 0.9) 50%,
    rgba(15, 60, 35, 0.95) 100%
  );
  box-shadow: 
    0 4rpx 20rpx rgba(0, 255, 136, 0.2),
    inset 0 0 30rpx rgba(0, 255, 136, 0.05);
}

/* 发光效果 */
.address-item {
  position: relative;
  overflow: hidden;
}

.address-item::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(0, 255, 136, 0.1) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
  pointer-events: none;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}