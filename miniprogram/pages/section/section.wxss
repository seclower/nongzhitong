/* 分区页面样式 */

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.header {
  background: linear-gradient(135deg, #6B8E6E 0%, #5A7A5D 100%);
  color: white;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(107, 142, 110, 0.3);
}

.back {
  font-size: 32rpx;
  cursor: pointer;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
}

.placeholder {
  width: 100rpx;
}

.section-content {
  margin-top: 140rpx;
  padding: 30rpx;
}

.product-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.product-item {
  background-color: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  cursor: pointer;
}

.product-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  width: 100%;
  height: 300rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16rpx;
}

.product-name {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  line-height: 1.4;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-price {
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 36rpx;
  font-weight: 600;
  color: #f44336;
}

.price-original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.product-sales {
  font-size: 24rpx;
  color: #999;
}

.no-results {
  margin-top: 300rpx;
  text-align: center;
  color: #999;
  font-size: 32rpx;
}