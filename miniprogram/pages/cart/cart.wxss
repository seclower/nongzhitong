/* 购物车页面样式 - 绿色科技感金属风格 */

/* 购物车商品列表 */
.cart-list {
  margin-bottom: 120rpx;
  position: relative;
  z-index: 1;
}

.cart-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.cart-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.cart-item:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 25rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.cart-item-left {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.cart-item-image {
  width: 150rpx;
  height: 150rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.1), rgba(0, 255, 136, 0.05));
  border-radius: 12rpx;
  margin-left: 20rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.3);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.cart-item-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 150rpx;
}

.cart-item-name {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 10rpx;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.cart-item-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 10rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.cart-item-quantity {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 50rpx;
  height: 50rpx;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 8rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.2), rgba(0, 255, 136, 0.1));
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  transition: all 0.3s ease;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.2);
}

.quantity-btn:active {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.2));
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.4);
  transform: scale(0.95);
}

.quantity {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.delete-btn {
  margin-left: 20rpx;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, rgba(255, 71, 87, 0.3), rgba(255, 71, 87, 0.15));
  color: #ffffff;
  border: 2rpx solid rgba(255, 71, 87, 0.4);
  border-radius: 8rpx;
  font-size: 24rpx;
  transition: all 0.3s ease;
  box-shadow: 0 0 10rpx rgba(255, 71, 87, 0.2);
}

.delete-btn:active {
  background: linear-gradient(135deg, rgba(255, 71, 87, 0.4), rgba(255, 71, 87, 0.25));
  box-shadow: 0 0 15rpx rgba(255, 71, 87, 0.3);
  transform: scale(0.95);
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 200rpx 20rpx;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 1;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
  filter: drop-shadow(0 0 20rpx rgba(0, 255, 136, 0.3));
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 30rpx;
  color: rgba(255, 255, 255, 0.6);
}

.go-shopping-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.15));
  color: #ffffff;
  border: 2rpx solid rgba(0, 255, 136, 0.5);
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
}

.go-shopping-btn:active {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.4), rgba(0, 255, 136, 0.25));
  box-shadow: 0 6rpx 25rpx rgba(0, 255, 136, 0.5);
  transform: translateY(-2rpx);
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  padding: 20rpx;
  border-top: 2rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 -2rpx 20rpx rgba(0, 255, 136, 0.3);
  z-index: 1000;
}

.select-all {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.select-all text {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.total-price {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: right;
  margin-right: 20rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.checkout-btn {
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.15));
  color: #ffffff;
  border: 2rpx solid rgba(0, 255, 136, 0.5);
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 600;
  min-width: 150rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
}

.checkout-btn:active {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.4), rgba(0, 255, 136, 0.25));
  box-shadow: 0 6rpx 25rpx rgba(0, 255, 136, 0.5);
  transform: translateY(-2rpx);
}

/* 复选框样式 */
.checkbox {
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 255, 136, 0.1);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 8rpx;
}

.checkbox-selected {
  background: linear-gradient(135deg, #00ff88, #00cc6a);
  border-color: #00ff88;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.4);
}