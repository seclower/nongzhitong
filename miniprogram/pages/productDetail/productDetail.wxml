<!-- 产品详情页面 -->
<view class="container">
  <!-- 产品图片 -->
  <view class="product-image">
    <image src="{{product.image}}" mode="aspectFill" style="width: 100%; height: 100%;" />
  </view>
  
  <!-- 产品信息 -->
  <view class="product-info">
    <view class="product-name">{{product.name}}</view>
    <view class="product-price">
      <text class="price-current">¥{{product.price}}</text>
      <text class="price-original" wx:if="{{product.originalPrice}}">¥{{product.originalPrice}}</text>
    </view>
    <view class="product-stock">库存: {{product.stock}}件</view>
  </view>
  
  <!-- 产品描述 -->
  <view class="product-description">
    <view class="section-title">产品描述</view>
    <view class="description-content">{{product.description}}</view>
  </view>
  
  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="action-buttons">
      <view class="action-btn" bindtap="onAddToFavorites">
        <view class="action-icon">❤️</view>
        <view class="action-text">收藏</view>
      </view>
      <view class="action-btn" bindtap="onAddToCart">
        <view class="icon icon-cart action-icon"></view>
        <view class="action-text">加入购物车</view>
      </view>
    </view>
    <button class="buy-btn" bindtap="onBuyNow">立即购买</button>
  </view>
</view>