<!-- 优惠券页面 -->
<view class="container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-title">优惠券</view>
    <view class="header-right"></view>
  </view>
  
  <view class="coupons-section">
    <view class="section-title">可使用</view>
    <view class="coupon-item" wx:for="{{validCoupons}}" wx:key="{{item.id}}">
      <view class="coupon-left">
        <view class="coupon-value">¥{{item.value}}</view>
        <view class="coupon-condition">满{{item.minAmount}}元可用</view>
      </view>
      <view class="coupon-right">
        <view class="coupon-title">{{item.title}}</view>
        <view class="coupon-expiry">有效期至：{{item.expiryDate}}</view>
        <view class="coupon-status valid">可使用</view>
      </view>
    </view>
  </view>
  
  <view class="coupons-section">
    <view class="section-title">已过期</view>
    <view class="coupon-item expired" wx:for="{{expiredCoupons}}" wx:key="{{item.id}}">
      <view class="coupon-left">
        <view class="coupon-value">¥{{item.value}}</view>
        <view class="coupon-condition">满{{item.minAmount}}元可用</view>
      </view>
      <view class="coupon-right">
        <view class="coupon-title">{{item.title}}</view>
        <view class="coupon-expiry">有效期至：{{item.expiryDate}}</view>
        <view class="coupon-status expired">已过期</view>
      </view>
    </view>
  </view>
</view>