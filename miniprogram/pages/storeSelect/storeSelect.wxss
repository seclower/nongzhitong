/* 门店选择页面样式 */

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.header {
  background: linear-gradient(135deg, #6B8E6E 0%, #5A7A5D 100%);
  color: white;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(107, 142, 110, 0.3);
}

.back {
  font-size: 32rpx;
  cursor: pointer;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
}

.placeholder {
  width: 100rpx;
}

.search-bar {
  margin-top: 140rpx;
  padding: 30rpx;
  background-color: white;
}

.search-input-container {
  position: relative;
  display: flex;
  align-items: center;
}

.search-icon {
  position: absolute;
  left: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.search-input {
  width: 100%;
  padding: 24rpx 30rpx 24rpx 90rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 50rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
  transition: all 0.3s ease;
}

.search-input:focus {
  border-color: #6B8E6E;
  background-color: white;
}

.store-list {
  padding: 30rpx;
}

.store-item {
  background-color: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  cursor: pointer;
}

.store-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.store-name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.store-address {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.store-distance {
  font-size: 24rpx;
  color: #999;
}