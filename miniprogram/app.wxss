/* 全局绿色科技感金属风格样式 */

page {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 卡片样式 - 金属科技感 */
.card {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4px 25rpx rgba(0, 255, 136, 0.25), inset 0 0 30rpx rgba(0, 255, 136, 0.05);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #00ff88, transparent);
}

/* 标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 按钮样式 - 绿色发光 */
.btn-primary {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.15));
  color: #ffffff;
  border: 2rpx solid rgba(0, 255, 136, 0.5);
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:hover {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.4), rgba(0, 255, 136, 0.25));
  box-shadow: 0 6rpx 25rpx rgba(0, 255, 136, 0.5);
  transform: translateY(-2rpx);
}

.btn-primary::after {
  display: none;
}

/* 次要按钮 */
.btn-secondary {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.btn-secondary:hover {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.1));
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.3);
  transform: translateY(-2rpx);
}

.btn-secondary::after {
  display: none;
}

/* 输入框样式 */
.input {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.8), rgba(10, 46, 26, 0.7));
  color: #ffffff;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.15), inset 0 0 10rpx rgba(0, 255, 136, 0.05);
}

.input:focus {
  border-color: #00ff88;
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.4), inset 0 0 15rpx rgba(0, 255, 136, 0.1);
}

.input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* 列表项样式 */
.list-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 15rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.list-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 0;
  background: linear-gradient(90deg, rgba(0, 255, 136, 0.2), transparent);
  transition: width 0.3s ease;
}

.list-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.list-item:active::before {
  width: 100%;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.2), rgba(0, 255, 136, 0.1));
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 22rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.4);
}

.tag-success {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.3), rgba(0, 255, 136, 0.15));
  color: #ffffff;
}

.tag-warning {
  background: linear-gradient(135deg, rgba(255, 193, 7, 0.3), rgba(255, 193, 7, 0.15));
  color: #ffffff;
}

.tag-danger {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.3), rgba(255, 107, 107, 0.15));
  color: #ffffff;
}

/* 价格样式 */
.price {
  color: #ffffff;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.price-original {
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
  font-size: 24rpx;
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.4), transparent);
  margin: 24rpx 0;
}

/* 徽章样式 */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #ff4757, #ff6b81);
  color: white;
  border-radius: 18rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(255, 71, 87, 0.4);
}

/* 导航栏样式 */
.navbar {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
}

.navbar::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

/* 底部标签栏样式 */
.tabbar {
  background: linear-gradient(180deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  box-shadow: 0 -2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-top: 2rpx solid rgba(0, 255, 136, 0.4);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 12rpx 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.3s ease;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.tabbar-item.active {
  color: #00ff88;
  background: rgba(0, 255, 136, 0.15);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.3);
}

.tabbar-item text {
  font-size: 20rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

/* 模态框样式 */
.modal {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.95) 100%);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.5), 0 0 50rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  overflow: hidden;
}

.modal-mask {
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(5px);
}

/* 进度条样式 */
.progress {
  background: rgba(0, 255, 136, 0.15);
  border-radius: 8rpx;
  height: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 255, 136, 0.3);
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, rgba(0, 255, 136, 0.7), rgba(0, 255, 136, 0.9));
  border-radius: 8rpx;
  transition: width 0.3s ease;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 搜索框样式 */
.search-bar {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9), rgba(10, 46, 26, 0.8));
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.2), inset 0 0 10rpx rgba(0, 255, 136, 0.05);
}

/* 空状态样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
  filter: drop-shadow(0 0 20rpx rgba(0, 255, 136, 0.3));
}

.empty-state-text {
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  text-align: center;
}

/* 加载状态样式 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-dot {
  width: 16rpx;
  height: 16rpx;
  background: #00ff88;
  border-radius: 50%;
  margin: 0 8rpx;
  animation: loadingPulse 1.4s infinite ease-in-out;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes loadingPulse {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 开关样式 */
.switch {
  background: rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
}

.switch-checked {
  background: linear-gradient(135deg, #00ff88, #00cc6a);
  border-color: #00ff88;
}

/* 复选框样式 */
.checkbox {
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 255, 136, 0.1);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 8rpx;
}

.checkbox-selected {
  background: linear-gradient(135deg, #00ff88, #00cc6a);
  border-color: #00ff88;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.4);
}

/* 单选框样式 */
.radio {
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 255, 136, 0.1);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 50%;
}

.radio-selected {
  background: linear-gradient(135deg, #00ff88, #00cc6a);
  border-color: #00ff88;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.4);
}

/* 头像样式 */
.avatar {
  border-radius: 50%;
  border: 4rpx solid rgba(0, 255, 136, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(0, 255, 136, 0.3);
}

/* 徽章文字 */
.badge-text {
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.5);
}

/* 图标容器样式 */
.icon-container {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.2), rgba(0, 255, 136, 0.1));
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.2);
}

/* 低饱和图标样式 */
.icon {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 255, 136, 0.8);
  border-radius: 8rpx;
  position: relative;
}

/* 搜索图标 */
.icon-search::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #ffffff;
  border-radius: 50%;
}

.icon-search::before {
  content: '';
  position: absolute;
  top: 70%;
  left: 70%;
  transform: translate(-50%, -50%) rotate(45deg);
  width: 10rpx;
  height: 2rpx;
  background-color: #ffffff;
}

/* 拼团图标 */
.icon-group::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 12rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

/* 团购图标 */
.icon-groupon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background-color: #ffffff;
  border-radius: 50%;
}

/* 秒杀图标 */
.icon-seckill::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) rotate(45deg);
  width: 24rpx;
  height: 24rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

/* 积分图标 */
.icon-points::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background-color: #ffffff;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

/* 公告图标 */
.icon-notice::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 24rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

/* 购物车图标 */
.icon-cart::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 20rpx;
  border: 2rpx solid #ffffff;
  border-radius: 2rpx;
}

.icon-cart::before {
  content: '';
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #ffffff;
  border-radius: 50%;
}

/* 日历图标 */
.icon-calendar::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

.icon-calendar::before {
  content: '';
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 6rpx;
  background-color: #ffffff;
  border-radius: 1rpx;
}

/* 订单图标 */
.icon-order::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 20rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

/* 收藏图标 */
.icon-favorite::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background-color: #ffffff;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
}

/* 语音图标 */
.icon-voice::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 20rpx;
  background-color: #ffffff;
  border-radius: 6rpx;
}

.icon-voice::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 70%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #ffffff;
  border-radius: 50%;
}

/* 视频图标 */
.icon-video::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid #ffffff;
}

/* 展馆图标 */
.icon-exhibition::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 20rpx;
  background-color: #ffffff;
  clip-path: polygon(10% 10%, 90% 10%, 95% 30%, 80% 30%, 80% 90%, 20% 90%, 20% 30%, 5% 30%);
}

/* 证书图标 */
.icon-certificate::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 20rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

/* 空购物车图标 */
.icon-empty-cart::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 20rpx;
  border: 2rpx solid #ffffff;
  border-radius: 2rpx;
}

/* 空订单图标 */
.icon-empty-order::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 20rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

/* 空日历图标 */
.icon-empty-calendar::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  background-color: #ffffff;
  border-radius: 2rpx;
}

/* 首页导航标签图标 */
.nav-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

/* 功能服务图标 */
.function-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 30rpx;
}

/* 搜索栏图标 */
.search-icon {
  width: 32rpx;
  height: 32rpx;
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 底部操作栏图标 */
.action-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 8rpx;
}