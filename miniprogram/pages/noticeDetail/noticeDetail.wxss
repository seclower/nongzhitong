/* 公告详情页面样式 - 绿色科技感金属风格 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  padding-bottom: 100rpx;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: white;
  padding: 0 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-left, .header-right {
  width: 88rpx;
  text-align: center;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 公告内容 */
.notice-content {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  margin-top: 88rpx;
  padding: 40rpx;
  min-height: calc(100vh - 88rpx);
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.notice-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.notice-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  line-height: 48rpx;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.notice-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.2);
}

.notice-date {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

.notice-source {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.notice-body {
  font-size: 24rpx;
  line-height: 40rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
}

.notice-body p {
  margin-bottom: 24rpx;
}

.notice-body ul {
  margin-bottom: 24rpx;
  padding-left: 40rpx;
}

.notice-body li {
  margin-bottom: 12rpx;
  list-style-type: disc;
  color: rgba(255, 255, 255, 0.8);
}
