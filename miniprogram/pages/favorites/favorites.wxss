/* 我的收藏页面样式 - 绿色科技感金属风格 */

.container {
  padding-bottom: 100rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: white;
  position: sticky;
  top: 0;
  z-index: 1000;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-left, .header-right {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  text-align: center;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.favorites-list {
  padding: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.product-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  transition: all 0.3s ease;
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
}

.product-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.product-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.product-image {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  background: rgba(0, 255, 136, 0.1);
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  line-height: 1.4;
  margin-bottom: 15rpx;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.product-price {
  margin-bottom: 10rpx;
}

.price-current {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.price-original {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
  margin-left: 15rpx;
}

.product-sales {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 600rpx;
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 100rpx;
  color: #00ff88;
  margin-bottom: 30rpx;
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.2) 0%, rgba(0, 204, 106, 0.1) 100%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 0 30rpx rgba(0, 255, 136, 0.3);
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}