/* 产品详情页面样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.back-icon {
  font-size: 40rpx;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  transition: all 0.3s ease;
}

.back-icon:hover {
  transform: translateX(-10rpx);
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.8);
}

/* 内容容器 */
.content {
  margin-top: 120rpx;
  position: relative;
  z-index: 1;
}

/* 产品图片 */
.product-image {
  width: 100%;
  height: 500rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.1) 0%, rgba(0, 204, 106, 0.05) 100%);
  margin-bottom: 30rpx;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-image::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.2) 0%, rgba(10, 46, 26, 0.1) 100%);
  pointer-events: none;
}

/* 产品信息 */
.product-info {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.product-info:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.product-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.product-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  line-height: 1.4;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 6rpx solid #00ff88;
  padding-left: 20rpx;
}

.product-price {
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 40rpx;
  font-weight: 600;
  color: #00ff88;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

.price-original {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
  margin-left: 24rpx;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
}

.product-stock {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
}

/* 产品描述 */
.product-description {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin-bottom: 140rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.product-description:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.product-description::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 6rpx solid #00ff88;
  padding-left: 20rpx;
}

.description-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
  padding-left: 20rpx;
  border-left: 4rpx solid rgba(0, 255, 136, 0.3);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  padding: 20rpx;
  border-top: 2rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 -2rpx 20rpx rgba(0, 255, 136, 0.3);
  z-index: 1000;
}

.action-buttons {
  display: flex;
  margin-right: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  transition: all 0.3s ease;
  padding: 10rpx;
  border-radius: 16rpx;
}

.action-btn:hover {
  background: rgba(0, 255, 136, 0.15);
  transform: translateY(-4rpx);
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
  color: #00ff88;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

.action-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.buy-btn {
  flex: 1;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  transition: all 0.3s ease;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.buy-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
  border-color: rgba(0, 255, 136, 0.6);
}

/* 金属感效果增强 */
.product-info,
.product-description {
  background: linear-gradient(
    135deg,
    rgba(15, 60, 35, 0.95) 0%,
    rgba(10, 46, 26, 0.9) 50%,
    rgba(15, 60, 35, 0.95) 100%
  );
  box-shadow: 
    0 4rpx 20rpx rgba(0, 255, 136, 0.2),
    inset 0 0 30rpx rgba(0, 255, 136, 0.05);
}

/* 发光效果 */
.product-info,
.product-description {
  position: relative;
  overflow: hidden;
}

.product-info::after,
.product-description::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(0, 255, 136, 0.1) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
  pointer-events: none;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}