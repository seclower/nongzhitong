<!-- 科普视频页面 -->
<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text>←</text>
    </view>
    <view class="header-title">科普视频</view>
    <view class="header-right" bindtap="uploadVideo">
      <text>上传</text>
    </view>
  </view>
  
  <!-- 视频分类 -->
  <view class="video-categories">
    <scroll-view scroll-x="true" class="category-scroll">
      <view class="category-item {{activeCategory === category.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-id="{{category.id}}">
        {{category.name}}
      </view>
    </scroll-view>
  </view>
  
  <!-- 视频列表 -->
  <view class="video-list">
    <view class="video-item" wx:for="{{videos}}" wx:key="id" bindtap="onVideoTap" data-id="{{item.id}}">
      <view class="video-thumbnail">
        <image src="{{item.thumbnail}}" mode="aspectFill" style="width: 100%; height: 100%;" />
        <view class="video-duration">{{item.duration}}</view>
      </view>
      <view class="video-info">
        <view class="video-title">{{item.title}}</view>
        <view class="video-meta">
          <view class="video-views">{{item.views}}次观看</view>
          <view class="video-date">{{item.date}}</view>
        </view>
        <view class="video-tags">
          <view class="video-tag" wx:for="{{item.tags}}" wx:key="index">{{tag}}</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 底部导航 -->
  <view class="footer">
    <view class="footer-item" bindtap="navigateToHome">
      <view class="icon icon-notice"></view>
      <span>首页</span>
    </view>
    <view class="footer-item" bindtap="navigateToCategory">
      <view class="icon icon-notice"></view>
      <span>分类</span>
    </view>
    <view class="footer-item" bindtap="navigateToCart">
      <view class="icon icon-cart"></view>
      <span>购物车</span>
    </view>
    <view class="footer-item" bindtap="navigateToCalendar">
      <view class="icon icon-calendar"></view>
      <span>农事</span>
    </view>
    <view class="footer-item active">
      <view class="icon icon-video"></view>
      <span>视频</span>
    </view>
    <view class="footer-item" bindtap="navigateToProfile">
      <view class="icon icon-notice"></view>
      <span>我的</span>
    </view>
  </view>
</view>