/* 限时秒杀页面样式 - 绿色科技感金属风格 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  padding-bottom: 100rpx;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: white;
  padding: 0 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-left, .header-right {
  width: 88rpx;
  text-align: center;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 秒杀时间 */
.seckill-time {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 20rpx 30rpx;
  margin-top: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.seckill-time::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.time-title {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.time-countdown {
  display: flex;
  align-items: center;
}

.time-item {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin: 0 4rpx;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.4);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.time-separator {
  font-size: 24rpx;
  font-weight: bold;
  color: #00ff88;
  margin: 0 4rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 秒杀商品列表 */
.seckill-list {
  padding: 20rpx;
  position: relative;
  z-index: 1;
}

.seckill-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.seckill-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.seckill-image {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  background: rgba(0, 255, 136, 0.1);
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.seckill-info {
  flex: 1;
}

.seckill-title {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  line-height: 40rpx;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.seckill-price {
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  margin-right: 16rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.price-original {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
}

.seckill-progress {
  margin-bottom: 20rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(0, 255, 136, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.3);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, rgba(0, 255, 136, 0.9), rgba(0, 204, 106, 0.8));
  border-radius: 4rpx;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.progress-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: right;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.seckill-actions {
  display: flex;
  justify-content: flex-end;
}

.buy-btn {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 20rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.buy-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
}
