/* 积分商城页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background-color: #6B8E6E;
  color: white;
  padding: 0 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
}

.header-left, .header-right {
  width: 88rpx;
  text-align: center;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
}

/* 积分信息 */
.points-info {
  background-color: #6B8E6E;
  color: white;
  padding: 40rpx 30rpx;
  margin-top: 88rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.points-value {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.points-label {
  font-size: 24rpx;
}

/* 积分商品列表 */
.points-list {
  padding: 20rpx;
}

.points-item {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.points-image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.points-info {
  flex: 1;
}

.points-title {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  line-height: 40rpx;
}

.points-price {
  margin-bottom: 20rpx;
}

.price-points {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-right: 16rpx;
}

.price-original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.points-actions {
  display: flex;
  justify-content: flex-end;
}

.exchange-btn {
  background-color: #6B8E6E;
  color: white;
  border: none;
  border-radius: 20rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
}
