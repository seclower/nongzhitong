<!-- 农业展览馆页面 -->
<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text>←</text>
    </view>
    <view class="header-title">农业展览馆</view>
    <view class="header-right"></view>
  </view>
  
  <!-- 展馆分类 -->
  <view class="exhibition-categories">
    <scroll-view scroll-x="true" class="category-scroll">
      <view class="category-item {{activeCategory === category.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-id="{{category.id}}">
        {{category.name}}
      </view>
    </scroll-view>
  </view>
  
  <!-- 展馆内容 -->
  <view class="exhibition-content">
    <view class="exhibition-item" wx:for="{{exhibitions}}" wx:key="id" bindtap="onExhibitionTap" data-id="{{item.id}}">
      <view class="exhibition-image">
        <image src="{{item.image}}" mode="aspectFill" style="width: 100%; height: 100%;" />
      </view>
      <view class="exhibition-info">
        <view class="exhibition-title">{{item.title}}</view>
        <view class="exhibition-desc">{{item.description}}</view>
        <view class="exhibition-tags">
          <view class="exhibition-tag" wx:for="{{item.tags}}" wx:key="index">{{tag}}</view>
        </view>
        <view class="exhibition-meta">
          <view class="exhibition-views">{{item.views}}次浏览</view>
          <view class="exhibition-certificate" wx:if="item.certificate">
            <view class="icon icon-certificate certificate-icon"></view>
            <text>资质认证</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 底部导航 -->
  <view class="footer">
    <view class="footer-item" bindtap="navigateToHome">
      <view class="icon icon-notice"></view>
      <span>首页</span>
    </view>
    <view class="footer-item" bindtap="navigateToCategory">
      <view class="icon icon-notice"></view>
      <span>分类</span>
    </view>
    <view class="footer-item" bindtap="navigateToCart">
      <view class="icon icon-cart"></view>
      <span>购物车</span>
    </view>
    <view class="footer-item" bindtap="navigateToCalendar">
      <view class="icon icon-calendar"></view>
      <span>农事</span>
    </view>
    <view class="footer-item" bindtap="navigateToVideos">
      <view class="icon icon-video"></view>
      <span>视频</span>
    </view>
    <view class="footer-item active">
      <view class="icon icon-exhibition"></view>
      <span>展馆</span>
    </view>
    <view class="footer-item" bindtap="navigateToProfile">
      <view class="icon icon-notice"></view>
      <span>我的</span>
    </view>
  </view>
</view>