/* 订单页面样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 内容容器 */
.content {
  margin-top: 120rpx;
  position: relative;
  z-index: 1;
}

/* 订单状态标签 */
.order-tabs {
  display: flex;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 0 30rpx;
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
  position: sticky;
  top: 120rpx;
  z-index: 999;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.2);
}

.order-tab {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  position: relative;
  transition: all 0.3s ease;
  border-radius: 40rpx;
  margin: 10rpx;
}

.order-tab:hover {
  background: rgba(0, 255, 136, 0.15);
  transform: translateY(-4rpx);
}

.order-tab.active {
  color: #00ff88;
  font-weight: 600;
  background: rgba(0, 255, 136, 0.15);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.3);
}

.order-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #00ff88, transparent);
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.order-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.order-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.order-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(0, 255, 136, 0.1);
}

.order-id {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.order-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-weight: 500;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.order-status.pending {
  background: rgba(255, 243, 205, 0.2);
  color: #ffd700;
  border: 2rpx solid rgba(255, 215, 0, 0.4);
  box-shadow: 0 0 10rpx rgba(255, 215, 0, 0.2);
}

.order-status.shipping {
  background: rgba(204, 231, 255, 0.2);
  color: #1e90ff;
  border: 2rpx solid rgba(30, 144, 255, 0.4);
  box-shadow: 0 0 10rpx rgba(30, 144, 255, 0.2);
}

.order-status.completed {
  background: rgba(212, 237, 218, 0.2);
  color: #00ff88;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.2);
}

.order-status.cancelled {
  background: rgba(248, 215, 218, 0.2);
  color: #ff6b6b;
  border: 2rpx solid rgba(255, 107, 107, 0.4);
  box-shadow: 0 0 10rpx rgba(255, 107, 107, 0.2);
}

/* 订单产品 */
.order-products {
  margin-bottom: 30rpx;
}

.order-product {
  display: flex;
  margin-bottom: 20rpx;
  background: rgba(0, 255, 136, 0.05);
  padding: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  transition: all 0.3s ease;
}

.order-product:hover {
  background: rgba(0, 255, 136, 0.1);
  transform: translateX(10rpx);
}

.order-product:last-child {
  margin-bottom: 0;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.1) 0%, rgba(0, 204, 106, 0.05) 100%);
  border-radius: 12rpx;
  margin-right: 20rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 12rpx;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.product-price {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
}

/* 订单 footer */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 255, 136, 0.1);
}

.order-total {
  font-size: 32rpx;
  font-weight: 600;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.order-time {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.2);
}

/* 空订单 */
.empty-order {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 200rpx 20rpx;
  color: rgba(255, 255, 255, 0.6);
  position: relative;
  z-index: 1;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  color: #00ff88;
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.2) 0%, rgba(0, 204, 106, 0.1) 100%);
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 0 30rpx rgba(0, 255, 136, 0.3);
}

.empty-text {
  font-size: 36rpx;
  margin-bottom: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.3);
}

.go-shopping-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  transition: all 0.3s ease;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.go-shopping-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
  border-color: rgba(0, 255, 136, 0.6);
}

/* 金属感效果增强 */
.order-item {
  background: linear-gradient(
    135deg,
    rgba(15, 60, 35, 0.95) 0%,
    rgba(10, 46, 26, 0.9) 50%,
    rgba(15, 60, 35, 0.95) 100%
  );
  box-shadow: 
    0 4rpx 20rpx rgba(0, 255, 136, 0.2),
    inset 0 0 30rpx rgba(0, 255, 136, 0.05);
}

/* 发光效果 */
.order-item,
.order-product {
  position: relative;
  overflow: hidden;
}

.order-item::after,
.order-product::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(0, 255, 136, 0.1) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
  pointer-events: none;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}