<!-- 超值拼团页面 -->
<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text>←</text>
    </view>
    <view class="header-title">超值拼团</view>
    <view class="header-right"></view>
  </view>
  
  <!-- 拼团商品列表 -->
  <view class="group-buy-list">
    <view class="group-buy-item" wx:for="{{groupBuyProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
      <view class="group-buy-image">
        <image src="{{item.image}}" mode="aspectFill" style="width: 100%; height: 100%;" />
      </view>
      <view class="group-buy-info">
        <view class="group-buy-title">{{item.name}}</view>
        <view class="group-buy-price">
          <span class="price-current">¥{{item.groupPrice}}</span>
          <span class="price-original">¥{{item.originalPrice}}</span>
        </view>
        <view class="group-buy-progress">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.progress}}%;"></view>
          </view>
          <view class="progress-text">已拼{{item.progress}}%</view>
        </view>
        <view class="group-buy-actions">
          <button class="join-btn" bindtap="onJoinGroupBuy" data-id="{{item.id}}">去拼团</button>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 空拼团 -->
  <view class="empty-group-buy" wx:if="{{groupBuyProducts.length === 0}}">
    <view class="icon icon-empty-group-buy empty-icon"></view>
    <view class="empty-text">暂无拼团活动</view>
    <navigator url="../index/index" class="go-shopping-btn">去购物</navigator>
  </view>
</view>