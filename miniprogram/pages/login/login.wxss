/* 登录页面样式 - 绿色科技感金属风格 */

.container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

.login-container {
  width: 90%;
  max-width: 600rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  position: relative;
  z-index: 1;
}

.login-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.login-form {
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 30rpx;
  position: relative;
}

.input {
  width: 100%;
  padding: 30rpx;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.8), rgba(10, 46, 26, 0.7));
  transition: all 0.3s ease;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15), inset 0 0 15rpx rgba(0, 255, 136, 0.05);
}

.input:focus {
  border-color: #00ff88;
  box-shadow: 0 0 25rpx rgba(0, 255, 136, 0.4), inset 0 0 20rpx rgba(0, 255, 136, 0.1);
  outline: none;
}

.input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.login-btn {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 30rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.login-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
}

.login-footer {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 40rpx;
}

.footer-text {
  display: block;
  margin-bottom: 10rpx;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.footer-text a {
  color: #00ff88;
  text-decoration: none;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.footer-text a:hover {
  color: #ffffff;
}