/* 分类页面样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 分类容器 */
.category-container {
  display: flex;
  height: calc(100vh - 120rpx);
  margin-top: 120rpx;
  position: relative;
  z-index: 1;
}

/* 左侧分类列表 */
.left-category {
  width: 240rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  overflow-y: auto;
  border-right: 2rpx solid rgba(0, 255, 136, 0.3);
  box-shadow: 2rpx 0 20rpx rgba(0, 255, 136, 0.2);
}

.category-item {
  padding: 30rpx 20rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  border-left: 4rpx solid transparent;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.category-item:hover {
  background: rgba(0, 255, 136, 0.15);
  transform: translateX(10rpx);
}

.category-item.active {
  background: rgba(0, 255, 136, 0.15);
  color: #00ff88;
  border-left-color: #00ff88;
  font-weight: 600;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.3);
}

.category-item.active::after {
  content: '';
  position: absolute;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  width: 4rpx;
  height: 40rpx;
  background: linear-gradient(180deg, transparent, #00ff88, transparent);
  border-radius: 2rpx;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 右侧产品列表 */
.right-products {
  flex: 1;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  padding: 30rpx;
  overflow-y: auto;
  position: relative;
}

.subcategory-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 6rpx solid #00ff88;
  padding-left: 20rpx;
}

/* 产品列表 */
.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 30rpx;
}

.product-item {
  width: calc(50% - 15rpx);
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.product-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.product-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.product-image {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.1) 0%, rgba(0, 204, 106, 0.05) 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
  overflow: hidden;
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16rpx;
}

.product-name {
  font-size: 28rpx;
  color: #ffffff;
  margin-bottom: 16rpx;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

/* 金属感效果增强 */
.left-category,
.product-item {
  background: linear-gradient(
    135deg,
    rgba(15, 60, 35, 0.95) 0%,
    rgba(10, 46, 26, 0.9) 50%,
    rgba(15, 60, 35, 0.95) 100%
  );
  box-shadow: 
    0 4rpx 20rpx rgba(0, 255, 136, 0.2),
    inset 0 0 30rpx rgba(0, 255, 136, 0.05);
}

/* 发光效果 */
.category-item,
.product-item {
  position: relative;
  overflow: hidden;
}

.category-item::after,
.product-item::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(0, 255, 136, 0.1) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
  pointer-events: none;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}