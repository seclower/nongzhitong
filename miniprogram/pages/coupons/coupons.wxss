/* 优惠券页面样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
  padding-bottom: 100rpx;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: white;
  position: sticky;
  top: 0;
  z-index: 1000;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-left, .header-right {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  transition: all 0.3s ease;
}

.back-icon:hover {
  transform: translateX(-10rpx);
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.8);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  flex: 1;
  text-align: center;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 内容容器 */
.content {
  margin-top: 120rpx;
  position: relative;
  z-index: 1;
}

.coupons-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 6rpx solid #00ff88;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
}

.coupon-item {
  display: flex;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  overflow: hidden;
  position: relative;
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
}

.coupon-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.coupon-item.expired {
  opacity: 0.6;
}

.coupon-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.coupon-left {
  width: 220rpx;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 2rpx 0 20rpx rgba(0, 255, 136, 0.3);
  border-right: 2rpx solid rgba(0, 255, 136, 0.4);
}

.coupon-left::after {
  content: '';
  position: absolute;
  right: -20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  box-shadow: inset 0 0 10rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
}

.coupon-value {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.8);
}

.coupon-condition {
  font-size: 26rpx;
  opacity: 0.9;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.coupon-right {
  flex: 1;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.coupon-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 4rpx solid rgba(0, 255, 136, 0.5);
  padding-left: 20rpx;
}

.coupon-expiry {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.coupon-status {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 15rpx;
  align-self: flex-start;
  font-weight: 500;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.coupon-status.valid {
  background: rgba(0, 255, 136, 0.2);
  color: #00ff88;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.2);
}

.coupon-status.expired {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 0 10rpx rgba(255, 255, 255, 0.1);
}

/* 金属感效果增强 */
.coupon-item {
  background: linear-gradient(
    135deg,
    rgba(15, 60, 35, 0.95) 0%,
    rgba(10, 46, 26, 0.9) 50%,
    rgba(15, 60, 35, 0.95) 100%
  );
  box-shadow: 
    0 4rpx 20rpx rgba(0, 255, 136, 0.2),
    inset 0 0 30rpx rgba(0, 255, 136, 0.05);
}

/* 发光效果 */
.coupon-item {
  position: relative;
  overflow: hidden;
}

.coupon-item::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(0, 255, 136, 0.1) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
  pointer-events: none;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}