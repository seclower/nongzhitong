/* 首页样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.store-select {
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.store-select::after {
  content: '▼';
  font-size: 24rpx;
  margin-left: 10rpx;
  color: rgba(0, 255, 136, 0.8);
}

/* 搜索栏 */
.search-bar {
  margin-top: 140rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9), rgba(10, 46, 26, 0.8));
  backdrop-filter: blur(10px);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.search-input-container {
  position: relative;
  display: flex;
  align-items: center;
}

.search-icon {
  position: absolute;
  left: 30rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.search-input {
  width: 100%;
  padding: 24rpx 30rpx 24rpx 90rpx;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 50rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.8), rgba(10, 46, 26, 0.7));
  color: #ffffff;
  transition: all 0.3s ease;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.15), inset 0 0 10rpx rgba(0, 255, 136, 0.05);
}

.search-input:focus {
  border-color: #00ff88;
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.4), inset 0 0 15rpx rgba(0, 255, 136, 0.1);
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* 导航标签 */
.nav-tabs {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  display: flex;
  overflow-x: auto;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
  position: sticky;
  top: 130rpx;
  z-index: 999;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.2);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.3);
}

.nav-tab {
  padding: 24rpx 40rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  white-space: nowrap;
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
  border-radius: 40rpx;
  margin: 10rpx;
  display: flex;
  align-items: center;
}

.nav-tab:hover {
  background: rgba(0, 255, 136, 0.15);
  transform: translateY(-4rpx);
}

.nav-tab.active {
  color: #00ff88;
  font-weight: 600;
  background: rgba(0, 255, 136, 0.15);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.3);
}

.nav-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #00ff88, transparent);
  border-radius: 2rpx;
}

.nav-icon {
  margin-right: 16rpx;
  font-size: 32rpx;
}

/* 轮播图 */
.banner {
  margin: 20rpx 30rpx;
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 25rpx rgba(0, 255, 136, 0.25);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
}

.banner swiper {
  width: 100%;
  height: 400rpx;
}

.banner image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

/* 产品区域 */
.product-section {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  margin-bottom: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 25rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  z-index: 1;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.section-more {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
}

.section-more::after {
  content: '›';
  font-size: 32rpx;
  margin-left: 10rpx;
  color: rgba(0, 255, 136, 0.8);
}

/* 产品列表 */
.product-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.product-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  transition: all 0.3s ease;
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.product-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.product-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.product-image {
  width: 100%;
  height: 300rpx;
  background: rgba(0, 255, 136, 0.1);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16rpx;
}

.product-name {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  line-height: 1.4;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.product-price {
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.price-original {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
  margin-left: 16rpx;
}

.product-sales {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 功能服务 */
.function-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
  position: relative;
  z-index: 1;
}

.function-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.function-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.function-item:hover {
  transform: translateY(-10rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
  border-color: rgba(0, 255, 136, 0.6);
}

.function-icon {
  font-size: 96rpx;
  margin-bottom: 30rpx;
  color: #00ff88;
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.5);
}

.function-label {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

/* 平台数据 */
.data-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  position: relative;
  z-index: 1;
}

.data-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.data-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.data-item:hover {
  transform: translateY(-10rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
  border-color: rgba(0, 255, 136, 0.6);
}

.data-value {
  font-size: 56rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

.data-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 响应式设计 */
@media (min-width: 768px) {
  .data-container {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* 响应式设计 */
@media (min-width: 1024px) {
  .product-list {
    grid-template-columns: repeat(4, 1fr);
  }
}