<!-- 分类页面 -->
<view class="container">
  <view class="category-container">
    <!-- 左侧分类列表 -->
    <view class="left-category">
      <view class="category-item {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item.id}}">
        {{item.name}}
      </view>
    </view>
    
    <!-- 右侧产品列表 -->
    <view class="right-products">
      <view class="subcategory-title">{{currentCategoryName}}</view>
      <view class="product-list">
        <view class="product-item" wx:for="{{categoryProducts}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
          <view class="product-image">
            <image src="{{item.image}}" mode="aspectFill" style="width: 100%; height: 100%;" />
          </view>
          <view class="product-name">{{item.name}}</view>
          <view class="product-price">¥{{item.price}}</view>
        </view>
      </view>
    </view>
  </view>
</view>