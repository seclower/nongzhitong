/* 个人中心页面样式 - 绿色科技感金属风格 */

/* 容器 */
.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

/* 顶部导航栏 */
.header {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: #ffffff;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 内容容器 */
.content {
  margin-top: 120rpx;
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

/* 用户信息区域 */
.user-info {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.user-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.2) 0%, rgba(0, 204, 106, 0.1) 100%);
  color: #00ff88;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 70rpx;
  margin-right: 30rpx;
  border: 3rpx solid rgba(0, 255, 136, 0.4);
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.3);
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 16rpx;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.arrow-right {
  font-size: 40rpx;
  color: rgba(0, 255, 136, 0.8);
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.3);
}

/* 订单区域 */
.order-section {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  padding: 30rpx;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.order-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  border-left: 6rpx solid #00ff88;
  padding-left: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.section-more:hover {
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.section-more::after {
  content: '›';
  font-size: 32rpx;
  margin-left: 10rpx;
  color: rgba(0, 255, 136, 0.8);
}

.order-types {
  display: flex;
  justify-content: space-around;
}

.order-type {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: rgba(0, 255, 136, 0.1);
  border-radius: 16rpx;
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 15rpx rgba(0, 255, 136, 0.2);
}

.order-type:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 25rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.order-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
  color: #00ff88;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

.order-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

/* 功能区域 */
.function-section {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.function-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.function-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(0, 255, 136, 0.1);
  transition: all 0.3s ease;
  position: relative;
}

.function-item:hover {
  background: rgba(0, 255, 136, 0.1);
  padding-left: 40rpx;
}

.function-item:last-child {
  border-bottom: none;
}

.function-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
  width: 60rpx;
  text-align: center;
}

.function-text {
  flex: 1;
  font-size: 30rpx;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.function-item .arrow-right {
  font-size: 32rpx;
}

/* 退出登录按钮 */
.logout-btn {
  width: 100%;
  padding: 30rpx;
  background: linear-gradient(135deg, rgba(244, 67, 54, 0.9) 0%, rgba(211, 47, 47, 0.8) 100%);
  color: white;
  border: none;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(244, 67, 54, 0.3);
  border: 2rpx solid rgba(244, 67, 54, 0.4);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.logout-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(244, 67, 54, 0.4);
  border-color: rgba(244, 67, 54, 0.6);
}

.logout-btn:active {
  transform: translateY(0);
}

/* 响应式设计 */
@media (min-width: 768px) {
  .order-types {
    grid-template-columns: repeat(5, 1fr);
  }
}

/* 金属感效果增强 */
.user-info,
.order-section,
.function-section {
  background: linear-gradient(
    135deg,
    rgba(15, 60, 35, 0.95) 0%,
    rgba(10, 46, 26, 0.9) 50%,
    rgba(15, 60, 35, 0.95) 100%
  );
  box-shadow: 
    0 4rpx 20rpx rgba(0, 255, 136, 0.2),
    inset 0 0 30rpx rgba(0, 255, 136, 0.05);
}

/* 发光效果 */
.order-type,
.function-item {
  position: relative;
  overflow: hidden;
}

.order-type::after,
.function-item::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(0, 255, 136, 0.1) 50%,
    transparent 70%
  );
  transform: rotate(45deg);
  animation: shine 3s infinite;
  pointer-events: none;
}

@keyframes shine {
  0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}