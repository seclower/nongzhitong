<!-- 购物车页面 -->
<view class="container">
  <!-- 购物车商品列表 -->
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
      <view class="cart-item-left">
        <checkbox value="{{item.id}}" checked="{{item.checked}}" bindchange="onCheckboxChange" data-id="{{item.id}}" />
        <view class="cart-item-image">
          <image src="{{item.image || 'D:\\M\\新建相册\\商品.png'}}" mode="aspectFill" style="width: 100%; height: 100%;" />
        </view>
      </view>
      <view class="cart-item-right">
        <view class="cart-item-name">{{item.name}}</view>
        <view class="cart-item-price">¥{{item.price}}</view>
        <view class="cart-item-quantity">
          <button class="quantity-btn" bindtap="onDecrease" data-id="{{item.id}}">-</button>
          <view class="quantity">{{item.quantity}}</view>
          <button class="quantity-btn" bindtap="onIncrease" data-id="{{item.id}}">+</button>
        </view>
      </view>
      <button class="delete-btn" bindtap="onDelete" data-id="{{item.id}}">删除</button>
    </view>
  </view>
  
  <!-- 空购物车 -->
  <view class="empty-cart" wx:else>
    <view class="icon icon-empty-cart empty-icon"></view>
    <view class="empty-text">购物车是空的</view>
    <navigator url="../index/index" class="go-shopping-btn">去购物</navigator>
  </view>
  
  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{cartItems.length > 0}}">
    <view class="select-all">
      <checkbox checked="{{selectAll}}" bindchange="onSelectAllChange" />
      <text>全选</text>
    </view>
    <view class="total-price">
      合计: ¥{{totalPrice}}
    </view>
    <button class="checkout-btn" bindtap="onCheckout">结算({{selectedCount}})</button>
  </view>
</view>