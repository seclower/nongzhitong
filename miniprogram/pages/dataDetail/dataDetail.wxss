/* 数据详情页面样式 */

.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.header {
  background: linear-gradient(135deg, #6B8E6E 0%, #5A7A5D 100%);
  color: white;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(107, 142, 110, 0.3);
}

.back {
  font-size: 32rpx;
  cursor: pointer;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
}

.placeholder {
  width: 100rpx;
}

.data-content {
  margin-top: 140rpx;
  padding: 30rpx;
}

.data-card {
  background-color: white;
  border-radius: 24rpx;
  padding: 60rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.data-value {
  font-size: 72rpx;
  font-weight: 600;
  color: #6B8E6E;
  margin-bottom: 20rpx;
}

.data-label {
  font-size: 32rpx;
  color: #666;
}

.data-chart {
  background-color: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #333;
}

.chart-placeholder {
  width: 100%;
  height: 300rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 32rpx;
}

.data-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
}

.stat-item {
  background-color: white;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  transition: all 0.3s ease;
}

.stat-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #6B8E6E;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}