/* 搜索结果页面样式 - 绿色科技感金属风格 */

.container {
  padding: 0;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.9) 0%, rgba(20, 80, 50, 0.85) 50%, rgba(15, 60, 35, 0.9) 100%);
  background-attachment: fixed;
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #ffffff;
  position: relative;
}

.container::before {
  content: '';
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 1000rpx;
  height: 1000rpx;
  background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

.header {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.98) 0%, rgba(10, 46, 26, 0.98) 100%);
  backdrop-filter: blur(10px);
  color: white;
  padding: 30rpx 30rpx;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 20rpx rgba(0, 255, 136, 0.3);
  border-bottom: 2rpx solid rgba(0, 255, 136, 0.4);
}

.header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.back {
  font-size: 32rpx;
  cursor: pointer;
  margin-right: 30rpx;
  color: #00ff88;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.search-input-container {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  padding: 24rpx 30rpx;
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  border-radius: 50rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.8), rgba(10, 46, 26, 0.7));
  color: #ffffff;
  transition: all 0.3s ease;
  margin-right: 20rpx;
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15), inset 0 0 15rpx rgba(0, 255, 136, 0.05);
}

.search-input:focus {
  border-color: #00ff88;
  box-shadow: 0 0 25rpx rgba(0, 255, 136, 0.4), inset 0 0 20rpx rgba(0, 255, 136, 0.1);
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.search-btn {
  background: linear-gradient(135deg, rgba(0, 255, 136, 0.9) 0%, rgba(0, 204, 106, 0.8) 100%);
  color: white;
  padding: 24rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.3);
  border: 2rpx solid rgba(0, 255, 136, 0.4);
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.search-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.4);
}

.search-results {
  margin-top: 140rpx;
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.result-item {
  background: linear-gradient(135deg, rgba(15, 60, 35, 0.95) 0%, rgba(10, 46, 26, 0.9) 100%);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 255, 136, 0.2);
  transition: all 0.3s ease;
  display: flex;
  cursor: pointer;
  border: 2rpx solid rgba(0, 255, 136, 0.3);
  position: relative;
  overflow: hidden;
}

.result-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 255, 136, 0.8), transparent);
}

.result-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 255, 136, 0.3);
  border-color: rgba(0, 255, 136, 0.6);
}

.product-image {
  width: 200rpx;
  height: 200rpx;
  background: rgba(0, 255, 136, 0.1);
  border-radius: 16rpx;
  margin-right: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 15rpx rgba(0, 255, 136, 0.15);
}

.product-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  margin-bottom: 16rpx;
  line-height: 1.4;
  display: -webkit-box;
  display: box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #ffffff;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}

.product-price {
  margin-bottom: 16rpx;
}

.price-current {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.price-original {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
  margin-left: 16rpx;
}

.product-sales {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.no-results {
  margin-top: 300rpx;
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 32rpx;
  position: relative;
  z-index: 1;
  text-shadow: 0 0 5rpx rgba(0, 255, 136, 0.3);
}