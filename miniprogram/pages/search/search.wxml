<view class="container">
  <view class="header">
    <view class="back" bindtap="onBack">← 返回</view>
    <view class="search-input-container">
      <input class="search-input" value="{{keyword}}" placeholder="搜索农资产品" bindinput="onSearchInput" bindconfirm="onSearch" />
      <view class="search-btn" bindtap="onSearch">搜索</view>
    </view>
  </view>
  
  <view class="search-results">
    <view class="result-item" bindtap="goToProductDetail" data-id="{{product.id}}" wx:for="{{searchResults}}" wx:key="{{product.id}}" wx:for-item="product">
      <view class="product-image">
        <image src="{{product.image}}" mode="aspectFill" />
      </view>
      <view class="product-info">
        <view class="product-name">{{product.name}}</view>
        <view class="product-price">
          <view class="price-current">¥{{product.price}}</view>
          <view class="price-original" wx:if="{{product.originalPrice}}">¥{{product.originalPrice}}</view>
        </view>
        <view class="product-sales">已售 {{product.sales}} 件</view>
      </view>
    </view>
  </view>
  
  <view class="no-results" wx:if="{{searchResults.length === 0}}">
    <text>暂无搜索结果</text>
  </view>
</view>