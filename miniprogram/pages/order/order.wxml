<!-- 订单页面 -->
<view class="container">
  <!-- 订单状态标签 -->
  <view class="order-tabs">
    <view class="order-tab {{activeTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="onTabChange">全部</view>
    <view class="order-tab {{activeTab === 'pending' ? 'active' : ''}}" data-tab="pending" bindtap="onTabChange">待处理</view>
    <view class="order-tab {{activeTab === 'shipping' ? 'active' : ''}}" data-tab="shipping" bindtap="onTabChange">配送中</view>
    <view class="order-tab {{activeTab === 'completed' ? 'active' : ''}}" data-tab="completed" bindtap="onTabChange">已完成</view>
  </view>
  
  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item" wx:for="{{orders}}" wx:key="id" bindtap="onOrderTap" data-id="{{item.id}}">
      <view class="order-header">
        <view class="order-id">订单号: {{item.id}}</view>
        <view class="order-status {{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="order-products">
        <view class="order-product" wx:for="{{item.products}}" wx:key="productId">
          <view class="product-image"></view>
          <view class="product-info">
            <view class="product-name">{{item.name}}</view>
            <view class="product-price">¥{{item.price}} x {{item.quantity}}</view>
          </view>
        </view>
      </view>
      <view class="order-footer">
        <view class="order-total">合计: ¥{{item.total}}</view>
        <view class="order-time">{{item.time}}</view>
      </view>
    </view>
  </view>
  
  <!-- 空订单 -->
  <view class="empty-order" wx:if="{{orders.length === 0}}">
    <view class="icon icon-empty-order empty-icon"></view>
    <view class="empty-text">暂无订单</view>
    <navigator url="../index/index" class="go-shopping-btn">去购物</navigator>
  </view>
</view>