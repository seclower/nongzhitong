<!-- 收货地址页面 -->
<view class="container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-title">收货地址</view>
    <view class="header-right" bindtap="addAddress">
      <text>新增</text>
    </view>
  </view>
  
  <view class="address-list">
    <view class="address-item" wx:for="{{addresses}}" wx:key="{{item.id}}">
      <view class="address-header">
        <view class="address-name">{{item.name}}</view>
        <view class="address-phone">{{item.phone}}</view>
        <view class="address-default" wx:if="{{item.isDefault}}">默认</view>
      </view>
      <view class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</view>
      <view class="address-actions">
        <view class="action-btn edit" bindtap="editAddress" data-id="{{item.id}}">编辑</view>
        <view class="action-btn delete" bindtap="deleteAddress" data-id="{{item.id}}">删除</view>
        <view class="action-btn default" bindtap="setDefault" data-id="{{item.id}}" wx:if="{{!item.isDefault}}">设为默认</view>
      </view>
    </view>
  </view>
  
  <view class="add-button" bindtap="addAddress">
    <text class="add-icon">+</text>
    <text>添加新地址</text>
  </view>
</view>